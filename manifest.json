{
  "manifest_version": 3,
  "name": "Conversor de Moedas",
  "version": "1.0",
  "description": "Converta valores entre moedas rapidamente e direto no navegador, sem precisar sair da janela atual.",
  "permissions": ["storage"],
  "host_permissions": ["https://api.exchangerate-api.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Conversor de Moedas"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}